APP_NAME="Exercise Library API"
APP_ENV=local
APP_KEY=
# Run `php artisan key:generate` after copying this file. APP_KEY must never be blank.
APP_DEBUG=false
# WARNING: set APP_DEBUG=false in production. true exposes full stack traces to API clients.
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# In production, set LOG_LEVEL=error and LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter
# for structured logs compatible with log aggregators (Datadog, CloudWatch, etc.)

# --- Database ---
# SQLite is for local development and tests only.
# In production, use MySQL or PostgreSQL and uncomment the variables below.
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=exercise_library
# DB_USERNAME=
# DB_PASSWORD=

# --- CORS ---
# Set to a comma-separated list of allowed origins in production.
# Must not be left empty (which disallows all) or set to * (which allows all).
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
